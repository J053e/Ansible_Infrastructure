[maxscale]
threads=auto

[db1]
type=server
address={{ hostvars['db1'].db_ip }}
port=3306
protocol=MariaDBBackend

[db2]
type=server
address={{ hostvars['db2'].db_ip }}
port=3306
protocol=MariaDBBackend

[MariaDB-Monitor]
type=monitor
module=mariadbmon
servers=db1,db2
user={{ maxscale_monitor_user }}
password={{ maxscale_monitor_password }}
monitor_interval=2s

[glpi-service]
type=service
router=readwritesplit
servers=db1,db2
user={{ maxscale_monitor_user }}
password={{ maxscale_monitor_password }}

[glpi-listener]
type=listener
service=glpi-service
protocol=MariaDBClient
port={{ maxscale_rw_port }}
