global
    log /dev/log local0
    log /dev/log local1 notice
    daemon
    maxconn 2048

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5s
    timeout client  50s
    timeout server  50s

frontend http_front
    bind {{ haproxy_vip }}:80
    default_backend glpi_back

backend glpi_back
    balance roundrobin
{% for backend in haproxy_backends %}
    server {{ backend.name }} {{ backend.ip }}:{{ backend.port }} check
{% endfor %}
