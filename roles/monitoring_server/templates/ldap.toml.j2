[[servers]]
host = "{{ ipa_server_hostname }}"
port = 389
use_ssl = false
start_tls = false
ssl_skip_verify = false
bind_dn = "{{ grafana_ldap_bind_dn }}"
bind_password = "{{ grafana_ldap_bind_password }}"
search_filter = "(uid=%s)"
search_base_dns = ["cn=users,cn=accounts,dc=infra,dc=lab"]

[servers.attributes]
name = "givenName"
surname = "sn"
username = "uid"
member_of = "memberOf"
email = "mail"

[[servers.group_mappings]]
group_dn = "cn=grp-grafana-admins,cn=groups,cn=accounts,dc=infra,dc=lab"
org_role = "Admin"

[[servers.group_mappings]]
group_dn = "cn=grp-grafana-viewers,cn=groups,cn=accounts,dc=infra,dc=lab"
org_role = "Viewer"
