global:
  smtp_smarthost: "{{ alert_smtp_smarthost }}"
  smtp_from: "{{ alert_email_from }}"
  smtp_auth_username: "{{ alert_smtp_auth_username }}"
  smtp_auth_password: "{{ alert_smtp_auth_password }}"
  smtp_require_tls: true

route:
  receiver: email-receiver
  group_by:
    - alertname
    - instance
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 1h

receivers:
  - name: email-receiver
    email_configs:
      - to: "{{ alert_email_to }}"
        send_resolved: true
