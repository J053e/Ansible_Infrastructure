apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://mon1.infra.lab:{{ prometheus_port }}
    isDefault: true

  - name: Loki
    type: loki
    access: proxy
    url: http://mon1.infra.lab:{{ loki_port }}

  - name: Alertmanager
    type: alertmanager
    access: proxy
    url: http://mon1.infra.lab:{{ alertmanager_port }}
