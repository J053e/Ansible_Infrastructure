{
  "id": null,
  "uid": "infra-overview",
  "title": "Infraestructura - Vista General",
  "tags": ["infra", "ansible", "podman"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Hosts monitoreados",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(up{job=\"node_exporter\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Hosts caídos",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(up{job=\"node_exporter\"} == 0)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU por host",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{ "{{instance}}" }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memoria usada por host",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{ "{{instance}}" }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disponibilidad HTTP GLPI / Wiki.js",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_http\"}",
          "legendFormat": "{{ "{{service}}" }}",
          "refId": "A"
        }
      ]
    }
  ]
}
